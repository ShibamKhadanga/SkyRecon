# SkyRecon Backend – Environment Configuration
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your PostgreSQL credentials.

# ── Application ──
APP_NAME=SkyRecon
APP_VERSION=1.0.0
DEBUG=true

# ── PostgreSQL Database ──
# Make sure the database "skyrecon" exists in your PostgreSQL instance.
# Run in psql:  CREATE DATABASE skyrecon;
DB_HOST=localhost
DB_PORT=5432
DB_NAME=skyrecon
DB_USER=postgres
DB_PASSWORD=postgres

# ── AI Engine ──
YOLO_MODEL=yolov8n.pt
CONFIDENCE_THRESHOLD=0.5
